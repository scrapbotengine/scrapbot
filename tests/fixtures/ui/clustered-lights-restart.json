{
  "schema_version": 1,
  "timeout_frames": 120,
  "actions": [
    {"action": "click", "target": {"text": "STOP", "origin": "editor"}},
    {"action": "wait", "frames": 2},
    {"action": "click", "target": {"text": "PLAY", "origin": "editor"}},
    {"action": "expect", "target": {"name": "__scrapbot_editor_status_text", "origin": "editor"}, "expect": "text", "text": "PLAY MODE  /  RUNNING  /  CHANGES ARE TEMPORARY"},
    {"action": "wait", "frames": 4},
    {"action": "capture", "target": {"name": "__scrapbot_editor_viewport", "origin": "editor"}}
  ]
}
