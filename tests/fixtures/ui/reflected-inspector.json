{
  "schema_version": 1,
  "timeout_frames": 120,
  "actions": [
    {"action": "click", "target": {"text": "STOP", "origin": "editor"}},
    {"action": "wait", "frames": 2},
    {"action": "click", "target": {"text": "Main Camera", "origin": "editor"}},
    {"action": "type", "target": {"text": "60.00", "origin": "editor"}, "text": "75"},
    {"action": "key", "key": "enter"},
    {"action": "expect", "target": {"text": "75.00", "origin": "editor"}, "expect": "text", "text": "75.00"},
    {"action": "expect", "target": {"name": "__scrapbot_editor_status_text", "origin": "editor"}, "expect": "text", "text": "STOPPED  /  UNSAVED"},
    {"action": "click", "target": {"text": "UNDO", "origin": "editor"}},
    {"action": "expect", "target": {"text": "60.00", "origin": "editor"}, "expect": "text", "text": "60.00"},
    {"action": "expect", "target": {"name": "__scrapbot_editor_status_text", "origin": "editor"}, "expect": "text", "text": "STOPPED"},
    {"action": "capture", "target": {"text": "CAMERA", "origin": "editor"}, "padding": 8}
  ]
}
